      "parser.add_argument(\"--${7:path}\", type=${8:S3Path}, required=False, help=\"${9:Path}\")",
      "",
      "args = parser.parse_args()",
      "$0"
    ],
    "description": "Create argparse CLI boilerplate with Option, UUID, and Path arguments"
  }
